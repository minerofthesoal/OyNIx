#!/usr/bin/make -f
# ============================================================
#  OyNIx Browser — debian/rules
#
#  Uses debhelper + cmake. When QT_PREFIX is set (or QT_ROOT_DIR /
#  Qt6_DIR from install-qt-action), Qt6 libraries are bundled into
#  /usr/lib/oynix so the package works without system Qt6.
# ============================================================

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# Build directory used by dh cmake buildsystem
BUILDDIR = build

# Package staging root
DESTDIR  = $(CURDIR)/debian/oynix
LIB_DIR  = $(DESTDIR)/usr/lib/oynix

# ── Resolve Qt prefix ────────────────────────────────────────
# CI sets QT_ROOT_DIR or Qt6_DIR via install-qt-action.
# Local builds can pass QT_PREFIX= to make or export it.
ifndef QT_PREFIX
  ifdef QT_ROOT_DIR
    QT_PREFIX = $(QT_ROOT_DIR)
  else ifdef Qt6_DIR
    QT_PREFIX = $(shell cd "$(Qt6_DIR)/../../.." 2>/dev/null && pwd)
  endif
endif

# Extra cmake arg when Qt prefix is known
CMAKE_QT_ARG = $(if $(QT_PREFIX),-DCMAKE_PREFIX_PATH=$(QT_PREFIX))

# Ninja if available
CMAKE_GEN = $(shell command -v ninja >/dev/null 2>&1 && echo "-GNinja")

# ── dh targets ────────────────────────────────────────────────
%:
	dh $@ --buildsystem=cmake --builddirectory=$(BUILDDIR)

override_dh_auto_configure:
	dh_auto_configure --builddirectory=$(BUILDDIR) -- \
		$(CMAKE_GEN) \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		$(CMAKE_QT_ARG)

override_dh_auto_build:
	dh_auto_build --builddirectory=$(BUILDDIR)

override_dh_auto_install:
	# ── Binary to /usr/lib/oynix (not /usr/bin) ──────────────
	install -d $(LIB_DIR)
	install -m755 $(BUILDDIR)/oynix $(LIB_DIR)/oynix
	# ── C# NativeAOT core ───────────────────────────────────
	@if [ -f "$(BUILDDIR)/dotnet/OyNIxCore.so" ]; then \
		install -m644 $(BUILDDIR)/dotnet/OyNIxCore.so $(LIB_DIR)/; \
		echo "  Installed OyNIxCore.so (NativeAOT)"; \
	fi
	# ── Launcher wrapper → /usr/bin/oynix ────────────────────
	install -d $(DESTDIR)/usr/bin
	install -m755 debian/oynix.wrapper $(DESTDIR)/usr/bin/oynix
	# ── Desktop entry ────────────────────────────────────────
	install -d $(DESTDIR)/usr/share/applications
	install -m644 debian/oynix.desktop $(DESTDIR)/usr/share/applications/oynix.desktop
	# ── Icons ────────────────────────────────────────────────
	@for size in 256 128 64 48; do \
		icon="assets/icon-$${size}.png"; \
		if [ -f "$$icon" ]; then \
			install -d $(DESTDIR)/usr/share/icons/hicolor/$${size}x$${size}/apps; \
			install -m644 "$$icon" $(DESTDIR)/usr/share/icons/hicolor/$${size}x$${size}/apps/oynix.png; \
		fi; \
	done
	@if [ -f "assets/icon.svg" ]; then \
		install -d $(DESTDIR)/usr/share/icons/hicolor/scalable/apps; \
		install -m644 assets/icon.svg $(DESTDIR)/usr/share/icons/hicolor/scalable/apps/oynix.svg; \
	fi
	# ── Themes ───────────────────────────────────────────────
	install -d $(DESTDIR)/usr/share/oynix/themes
	@if [ -d "themes" ]; then \
		cp -r themes/* $(DESTDIR)/usr/share/oynix/themes/ 2>/dev/null || true; \
	fi
	# ── Bundle Qt6 (when using non-system Qt) ────────────────
	@if [ -n "$(QT_PREFIX)" ] && [ -d "$(QT_PREFIX)/lib" ]; then \
		echo "Bundling Qt6 from $(QT_PREFIX)..."; \
		chmod +x debian/bundle-qt.sh; \
		debian/bundle-qt.sh "$(LIB_DIR)" "$(QT_PREFIX)"; \
	else \
		echo "No QT_PREFIX set — assuming system Qt6 (no bundling)"; \
	fi

override_dh_auto_test:
	# No test suite yet
	@true

override_dh_shlibdeps:
	dh_shlibdeps -l$(LIB_DIR) -- --ignore-missing-info 2>/dev/null || true

override_dh_strip:
	dh_strip --no-automatic-dbgsym || true

override_dh_auto_clean:
	dh_auto_clean --builddirectory=$(BUILDDIR)
	rm -rf $(BUILDDIR)
