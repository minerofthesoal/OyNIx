#!/bin/bash
# ============================================================
#  oynix — CLI launcher for OyNIx Browser on Ubuntu/Mint
#
#  Usage:
#    oynix                         Open browser (new window)
#    oynix https://example.com     Open URL directly
#    oynix --search "query"        Search with Nyx
#    oynix --private               Open in private/incognito mode
#    oynix --profile <name>        Open with specific profile
#    oynix --version               Show version info
#    oynix --status                Show database & config status
#    oynix --reset-config          Reset to default configuration
#    oynix --export-db <file>      Export database to JSONL
#    oynix --help                  Show this help
#
#  Environment:
#    OYNIX_HOME      Config directory (default: ~/.config/oynix)
#    OYNIX_DEBUG     Set to 1 for debug output
#    OYNIX_SCALE     Qt scale factor (e.g., 1.5 for HiDPI)
# ============================================================
set -euo pipefail

VERSION="3.1.0"

# ── Locate OyNIx binary ──────────────────────────────────────
find_oynix() {
    # 1) System install
    if [ -f /usr/lib/oynix/oynix ]; then
        OYNIX_BIN="/usr/lib/oynix/oynix"
        OYNIX_DIR="/usr/lib/oynix"
        return 0
    fi

    # 2) Local install
    if [ -f "${HOME}/.local/lib/oynix/oynix" ]; then
        OYNIX_BIN="${HOME}/.local/lib/oynix/oynix"
        OYNIX_DIR="${HOME}/.local/lib/oynix"
        return 0
    fi

    # 3) Development build (look relative to this script)
    local script_dir
    script_dir="$(cd "$(dirname "$0")" && pwd)"
    local project_dir
    project_dir="$(cd "${script_dir}/.." && pwd)"

    for build_dir in \
        "${project_dir}/_build_ubuntu" \
        "${project_dir}/build/release" \
        "${project_dir}/build/debug" \
        "${project_dir}/build" \
        "${project_dir}/_build_deb"; do
        if [ -f "${build_dir}/oynix" ]; then
            OYNIX_BIN="${build_dir}/oynix"
            OYNIX_DIR="${build_dir}"
            return 0
        fi
    done

    # 4) PATH lookup
    local found
    found=$(command -v oynix 2>/dev/null || true)
    if [ -n "$found" ] && [ "$found" != "$0" ] && [ "$found" != "$(readlink -f "$0")" ]; then
        OYNIX_BIN="$found"
        OYNIX_DIR="$(dirname "$found")"
        return 0
    fi

    return 1
}

# ── Setup environment ─────────────────────────────────────────
setup_env() {
    export LD_LIBRARY_PATH="${OYNIX_DIR}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

    # Qt plugin/resource paths (for bundled installs)
    if [ -d "${OYNIX_DIR}/plugins" ]; then
        export QT_PLUGIN_PATH="${OYNIX_DIR}/plugins"
    fi
    if [ -f "${OYNIX_DIR}/libexec/QtWebEngineProcess" ]; then
        export QTWEBENGINEPROCESS_PATH="${OYNIX_DIR}/libexec/QtWebEngineProcess"
    fi
    if [ -d "${OYNIX_DIR}/resources" ]; then
        export QTWEBENGINE_RESOURCES_PATH="${OYNIX_DIR}/resources"
    fi
    if [ -d "${OYNIX_DIR}/translations" ]; then
        export QTWEBENGINE_LOCALES_PATH="${OYNIX_DIR}/translations"
    fi

    # User overrides
    if [ -n "${OYNIX_SCALE:-}" ]; then
        export QT_SCALE_FACTOR="${OYNIX_SCALE}"
    fi

    # Wayland / X11 platform selection
    # CLI flags --wayland / --x11 are also handled by the binary itself,
    # but we set the env here so child processes inherit the setting.
    if [ -z "${QT_QPA_PLATFORM:-}" ]; then
        local use_wayland=false use_x11=false
        for a in "$@"; do
            case "$a" in
                --wayland) use_wayland=true ;;
                --x11|--xcb) use_x11=true ;;
            esac
        done
        if $use_wayland; then
            export QT_QPA_PLATFORM="wayland"
        elif $use_x11; then
            export QT_QPA_PLATFORM="xcb"
        elif [ -n "${WAYLAND_DISPLAY:-}" ]; then
            export QT_QPA_PLATFORM="wayland;xcb"
        fi
    fi
}

# ── Config directory ──────────────────────────────────────────
OYNIX_HOME="${OYNIX_HOME:-${HOME}/.config/oynix}"

# ── Subcommands ───────────────────────────────────────────────
cmd_help() {
    cat <<EOF
OyNIx Browser v${VERSION} — Chromium-based browser with Nyx search

Usage:
  oynix [options] [url...]

Options:
  (no args)               Open browser (home page)
  <url>                   Open URL(s) in new tab(s)
  -s, --search <query>    Search with Nyx search engine
  -p, --private           Open in private browsing mode
  --profile <name>        Use a specific browser profile
  --wayland               Force Wayland display backend
  --x11                   Force X11/XCB display backend
  --version               Show version and build info
  --status                Show database and config status
  --reset-config          Reset to default configuration
  --export-db <file>      Export site database as JSONL
  --config-dir            Print config directory path
  --debug                 Enable debug output
  -h, --help              Show this help message

Environment:
  OYNIX_HOME       Config directory (default: ~/.config/oynix)
  OYNIX_DEBUG      Set to 1 for verbose debug output
  OYNIX_SCALE      DPI scale factor (e.g., 1.5)
  QT_QPA_PLATFORM  Display backend (wayland, xcb, wayland;xcb)

Build from source:
  ./scripts/build-ubuntu.sh --deps-only   # install dependencies
  ./scripts/build-ubuntu.sh               # build
  ./scripts/build-ubuntu.sh --install     # install to ~/.local

Project: https://github.com/minerofthesoal/OyNIx
EOF
}

cmd_version() {
    echo "OyNIx Browser v${VERSION}"
    echo "  Qt6 WebEngine + C++17 + .NET 8 NativeAOT"
    echo ""

    if find_oynix 2>/dev/null; then
        echo "  Binary:  ${OYNIX_BIN}"
        local bin_size
        bin_size=$(du -sh "${OYNIX_BIN}" 2>/dev/null | awk '{print $1}')
        echo "  Size:    ${bin_size}"

        # Check C# core
        if [ -f "${OYNIX_DIR}/OyNIxCore.so" ]; then
            local core_size
            core_size=$(du -sh "${OYNIX_DIR}/OyNIxCore.so" 2>/dev/null | awk '{print $1}')
            echo "  C# Core: ${core_size}"
        fi
    else
        echo "  Binary:  not found"
    fi

    echo "  Config:  ${OYNIX_HOME}"
}

cmd_status() {
    echo "OyNIx Browser Status"
    echo "===================="
    echo ""
    echo "Config: ${OYNIX_HOME}"

    # Database
    local db="${OYNIX_HOME}/nyx_index.db"
    if [ -f "$db" ]; then
        local db_size
        db_size=$(du -sh "$db" 2>/dev/null | awk '{print $1}')
        echo "Database: ${db} (${db_size})"

        # Count tables with sqlite3 if available
        if command -v sqlite3 &>/dev/null; then
            local sites pages
            sites=$(sqlite3 "$db" "SELECT COUNT(*) FROM sites;" 2>/dev/null || echo "?")
            pages=$(sqlite3 "$db" "SELECT COUNT(*) FROM pages;" 2>/dev/null || echo "?")
            local domains
            domains=$(sqlite3 "$db" "SELECT COUNT(DISTINCT domain) FROM pages WHERE domain != '';" 2>/dev/null || echo "?")
            echo "  Sites:    ${sites}"
            echo "  Pages:    ${pages}"
            echo "  Domains:  ${domains}"
        fi
    else
        echo "Database: not created yet"
    fi

    # Config file
    local conf="${OYNIX_HOME}/config.json"
    if [ -f "$conf" ]; then
        echo ""
        echo "Config (${conf}):"
        if command -v python3 &>/dev/null; then
            python3 -m json.tool "$conf" 2>/dev/null | head -20
        else
            head -20 "$conf"
        fi
    fi

    # Extensions
    local ext_dir="${OYNIX_HOME}/extensions"
    if [ -d "$ext_dir" ]; then
        local ext_count
        ext_count=$(find "$ext_dir" -maxdepth 1 -type d | tail -n +2 | wc -l)
        echo ""
        echo "Extensions: ${ext_count} installed"
    fi

    # Profiles
    local prof_dir="${OYNIX_HOME}/profiles"
    if [ -d "$prof_dir" ]; then
        echo "Profiles:"
        for p in "${prof_dir}"/*/; do
            [ -d "$p" ] && echo "  - $(basename "$p")"
        done
    fi
}

cmd_export_db() {
    local output="${1:-oynix_export.jsonl}"

    local db="${OYNIX_HOME}/nyx_index.db"
    if [ ! -f "$db" ]; then
        echo "Error: Database not found at ${db}" >&2
        exit 1
    fi

    if ! command -v sqlite3 &>/dev/null; then
        echo "Error: sqlite3 not found — install with: sudo apt install sqlite3" >&2
        exit 1
    fi

    echo "Exporting database to ${output}..."

    # Export pages as JSONL
    sqlite3 -json "$db" \
        "SELECT url, title, content, domain, source, visited_at AS indexed_at FROM pages;" \
        2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
for row in data:
    print(json.dumps(row, ensure_ascii=False))
" > "$output" 2>/dev/null || {
        # Fallback without python3 json splitting
        sqlite3 "$db" -separator '	' \
            "SELECT url, title, domain, COALESCE(source,'nyx') FROM pages;" | \
        while IFS=$'\t' read -r url title domain source; do
            printf '{"url":"%s","title":"%s","domain":"%s","source":"%s"}\n' \
                "$url" "$title" "$domain" "$source"
        done > "$output"
    }

    # Append sites
    sqlite3 -json "$db" \
        "SELECT url, title, description, category, rating, source, added_at FROM sites;" \
        2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
for row in data:
    print(json.dumps(row, ensure_ascii=False))
" >> "$output" 2>/dev/null || true

    local count
    count=$(wc -l < "$output")
    local size
    size=$(du -sh "$output" | awk '{print $1}')
    echo "Exported ${count} entries (${size}) to ${output}"
}

cmd_reset_config() {
    echo "This will reset OyNIx configuration to defaults."
    echo "Your bookmarks, history, and extensions will be preserved."
    echo ""
    read -rp "Continue? [y/N] " ans
    if [[ ! "$ans" =~ ^[Yy] ]]; then
        echo "Cancelled."
        exit 0
    fi

    local conf="${OYNIX_HOME}/config.json"
    if [ -f "$conf" ]; then
        cp "$conf" "${conf}.bak"
        echo "Backed up to ${conf}.bak"
    fi
    rm -f "$conf"
    echo "Configuration reset. Restart OyNIx to apply defaults."
}

# ── Main ──────────────────────────────────────────────────────
BROWSER_ARGS=()
DEBUG_MODE="${OYNIX_DEBUG:-0}"

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            cmd_help
            exit 0
            ;;
        --version)
            cmd_version
            exit 0
            ;;
        --status)
            cmd_status
            exit 0
            ;;
        --config-dir)
            echo "${OYNIX_HOME}"
            exit 0
            ;;
        --reset-config)
            cmd_reset_config
            exit 0
            ;;
        --export-db)
            shift
            cmd_export_db "${1:-oynix_export.jsonl}"
            exit 0
            ;;
        -s|--search)
            shift
            if [ -z "${1:-}" ]; then
                echo "Error: --search requires a query argument" >&2
                exit 1
            fi
            BROWSER_ARGS+=("oyn://search?q=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$1'))" 2>/dev/null || echo "$1")")
            shift
            ;;
        -p|--private)
            export OYNIX_PRIVATE=1
            BROWSER_ARGS+=("--private")
            shift
            ;;
        --profile)
            shift
            if [ -z "${1:-}" ]; then
                echo "Error: --profile requires a name argument" >&2
                exit 1
            fi
            export OYNIX_PROFILE="$1"
            BROWSER_ARGS+=("--profile" "$1")
            shift
            ;;
        --debug)
            DEBUG_MODE=1
            export OYNIX_DEBUG=1
            export QT_LOGGING_RULES="*.debug=true"
            shift
            ;;
        -*)
            # Pass unknown flags through to the binary
            BROWSER_ARGS+=("$1")
            shift
            ;;
        *)
            # URLs or file paths
            if [[ "$1" =~ ^https?:// ]] || [[ "$1" =~ ^oyn:// ]] || [[ "$1" =~ ^file:// ]]; then
                BROWSER_ARGS+=("$1")
            elif [ -f "$1" ]; then
                # Convert file path to file:// URL
                BROWSER_ARGS+=("file://$(readlink -f "$1")")
            else
                # Assume it's a URL without protocol
                BROWSER_ARGS+=("https://$1")
            fi
            shift
            ;;
    esac
done

# Find and validate the binary
if ! find_oynix; then
    echo "Error: OyNIx browser binary not found." >&2
    echo "" >&2
    echo "Checked locations:" >&2
    echo "  /usr/lib/oynix/oynix" >&2
    echo "  ~/.local/lib/oynix/oynix" >&2
    echo "  ./build/oynix, ./_build_ubuntu/oynix" >&2
    echo "" >&2
    echo "Build from source:" >&2
    echo "  ./scripts/build-ubuntu.sh --deps-only" >&2
    echo "  ./scripts/build-ubuntu.sh" >&2
    echo "" >&2
    echo "Or install the .deb package:" >&2
    echo "  sudo apt install ./oynix-*.deb" >&2
    exit 1
fi

# Setup runtime environment
setup_env

if [ "$DEBUG_MODE" = "1" ]; then
    echo "[debug] Binary:   ${OYNIX_BIN}"
    echo "[debug] Lib dir:  ${OYNIX_DIR}"
    echo "[debug] Config:   ${OYNIX_HOME}"
    echo "[debug] Args:     ${BROWSER_ARGS[*]:-<none>}"
    echo "[debug] LD_LIBRARY_PATH: ${LD_LIBRARY_PATH:-<not set>}"
    echo ""
fi

# Launch
exec "${OYNIX_BIN}" "${BROWSER_ARGS[@]+"${BROWSER_ARGS[@]}"}"
