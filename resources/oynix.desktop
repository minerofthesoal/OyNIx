[Desktop Entry]
Name=OyNIx Browser
Comment=The Nyx-Powered Chromium Browser
Exec=oynix %u
Icon=oynix
Terminal=false
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;x-scheme-handler/http;x-scheme-handler/https;x-scheme-handler/oyn;
Keywords=browser;web;internet;ai;nyx;wayland;
StartupNotify=true
StartupWMClass=oynix

Actions=wayland;x11;

[Desktop Action wayland]
Name=OyNIx Browser (Wayland)
Exec=oynix --wayland %u

[Desktop Action x11]
Name=OyNIx Browser (X11)
Exec=oynix --x11 %u
